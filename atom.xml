    <link href="http://example.com/2022/03/31/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C/IPv6/"/>
    <id>http://example.com/2022/03/31/%E8%AE%A1%E7%AE%97%E6%9C%BA%E7%BD%91%E7%BB%9C/IPv6/</id>
    <published>2022-03-31T09:25:12.000Z</published>
    <updated>2022-04-12T10:00:27.299Z</updated>
    
    <content type="html"><![CDATA[<h1 id="IPv6"><a href="#IPv6" class="headerlink" title="IPv6"></a>IPv6</h1><h2 id="为什么要有IPv6？"><a href="#为什么要有IPv6？" class="headerlink" title="为什么要有IPv6？"></a>为什么要有IPv6？</h2><p><img src="https://www.halisi7.space/202203311715982.png" alt="image-20220331171532837"></p><h2 id="IPv6数据报格式"><a href="#IPv6数据报格式" class="headerlink" title="IPv6数据报格式"></a>IPv6数据报格式</h2><p><img src="https://www.halisi7.space/202203311717132.png" alt="image-20220331171746874"></p><p><img src="https://www.halisi7.space/202203311723214.png" alt="image-20220331172346066"></p><h2 id="IPv6和IPv4"><a href="#IPv6和IPv4" class="headerlink" title="IPv6和IPv4"></a>IPv6和IPv4</h2><p><img src="https://www.halisi7.space/202203311728463.png" alt="image-20220331172802300"></p><h2 id="IPv6地址表示形式"><a href="#IPv6地址表示形式" class="headerlink" title="IPv6地址表示形式"></a>IPv6地址表示形式</h2><p><img src="https://www.halisi7.space/202203311729546.png" alt="image-20220331172952412"></p><ul><li>不再使用点分十进制。</li></ul><h2 id="IPv6基本地址类型"><a href="#IPv6基本地址类型" class="headerlink" title="IPv6基本地址类型"></a>IPv6基本地址类型</h2><p><img src="https://www.halisi7.space/202203311731615.png" alt="image-20220331173119472"></p><h2 id="IPv6向IPv4过渡的策略"><a href="#IPv6向IPv4过渡的策略" class="headerlink" title="IPv6向IPv4过渡的策略"></a>IPv6向IPv4过渡的策略</h2><p><img src="https://www.halisi7.space/202203311733047.png" alt="image-20220331173345851"></p><ul><li>将IPv6封装到IPv4的数据报中。</li></ul><h1 id="脑图时刻"><a href="#脑图时刻" class="headerlink" title="脑图时刻"></a>脑图时刻</h1><p><img src="https://www.halisi7.space/202203311734126.png" alt="image-20220331173416003"></p>]]></content>
    
    
